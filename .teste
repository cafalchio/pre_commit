# Local Test Commands Extracted from GitHub Workflows
# =====================================================
# These are test commands that can be run locally, extracted from .github/workflows/
# Python version matrices and CI-specific build steps have been excluded.

## Python Tests & Coverage (pytest.yml)
# ------------------------------------------------------

# Run full test suite with coverage (fail under 95%)
uv run pytest -n auto \
  --durations=5 \
  --ignore=tests/fuzz \
  --ignore=tests/e2e/test_entra_id_integration.py \
  --cov=mcpgateway \
  --cov-report=xml \
  --cov-report=html \
  --cov-report=term \
  --cov-branch \
  --cov-fail-under=95

# Diff-cover: enforce 95% coverage on changed lines (for PRs)
uv run diff-cover coverage.xml \
  --compare-branch=origin/main \
  --fail-under=95

# Run doctests with coverage (fail under 30%)
uv run pytest -n auto \
  --doctest-modules mcpgateway/ \
  --cov=mcpgateway \
  --cov-report=term \
  --cov-report=json:doctest-coverage.json \
  --cov-fail-under=30 \
  --tb=short

# Doctest validation
uv run python3 -m pytest --doctest-modules mcpgateway/ --tb=no -q


## Python Linting (lint.yml)
# ------------------------------------------------------

# Flake8
flake8 mcpgateway
flake8 plugins

# Ruff
ruff check mcpgateway
ruff check plugins

# Unimport
unimport mcpgateway
unimport plugins

# Vulture (dead code detection)
vulture mcpgateway --min-confidence 80 --exclude "*_pb2.py,*_pb2_grpc.py"
vulture plugins --min-confidence 80 --exclude "*_pb2.py,*_pb2_grpc.py"

# Pylint
uv run pylint mcpgateway --rcfile=.pylintrc.mcpgateway --fail-on E --fail-under=10
uv run pylint plugins --rcfile=.pylintrc.plugins --fail-on E --fail-under=10

# Interrogate (docstring coverage)
interrogate -vv mcpgateway --fail-under 100
interrogate -vv plugins --fail-under 100

# Radon (complexity analysis)
radon cc mcpgateway --min C --show-complexity && radon mi mcpgateway --min B
radon cc plugins --min C --show-complexity && radon mi plugins --min B


## Syntax Checks (lint.yml)
# ------------------------------------------------------

# YAML linting
yamllint -c .yamllint .

# JSON linting
find . -type f -name '*.json' -not -path './node_modules/*' -print0 | xargs -0 -I{} jq empty "{}"

# TOML linting
find . -type f -name '*.toml' \
  -not -path './plugin_templates/*' \
  -not -path './mcp-servers/templates/*' \
  -print0 | xargs -0 -I{} tomlcheck "{}"


## Security Scanning (bandit.yml)
# ------------------------------------------------------

# Bandit security scan (medium/high confidence)
bandit -r mcpgateway -ll -ii


## Playwright UI Tests (playwright.yml)
# ------------------------------------------------------

# Run Playwright CI smoke tests (requires gateway running on localhost:4444)
make test-ui-ci-smoke


## JavaScript Tests (vitest.yml)
# ------------------------------------------------------

# Install dependencies
npm ci

# Run Vitest
npx vitest run


## Web Linting (lint-web.yml)
# ------------------------------------------------------

# HTMLHint
npm install --no-save --legacy-peer-deps htmlhint
npx htmlhint "mcpgateway/templates/*.html"

# Stylelint
npm install --no-save --legacy-peer-deps stylelint stylelint-config-standard @stylistic/stylelint-config stylelint-order
npx stylelint "mcpgateway/static/*.css"

# ESLint
npm install --no-save eslint neostandard eslint-config-prettier eslint-plugin-prettier prettier
npx eslint "mcpgateway/static/*.js"

# Retire.js (security)
npm install --no-save --legacy-peer-deps retire
npx retire --path mcpgateway/static

# npm audit
npm audit --audit-level=high || true

# JSHint
npm install --no-save --legacy-peer-deps jshint
npx jshint --config .jshintrc "mcpgateway/static/*.js"

# JSCPD (copy-paste detection)
npm install --no-save --legacy-peer-deps jscpd
npx jscpd "mcpgateway/static/" "mcpgateway/templates/"

# NodeJSScan (Python-based JS security scanner)
pip install nodejsscan
nodejsscan --directory ./mcpgateway/static


## Database Migration Tests (alembic-upgrade-validation.yml)
# ------------------------------------------------------

# Run upgrade validation script
bash scripts/ci/run_upgrade_validation.sh


## License Checking (license-check.yml)
# ------------------------------------------------------

# Install tools
pip install pip-licenses
go install github.com/google/go-licenses@latest
cargo install cargo-license

# Run license checker
python scripts/license_checker.py \
  --config license-policy.toml \
  --report-json license-check-report.json


## Rust Plugin Tests (rust-plugins.yml)
# ------------------------------------------------------

# Check formatting
cd plugins_rust && make fmt-check

# Run Clippy
cd plugins_rust && make clippy

# Run Rust tests
cd plugins_rust && make test-verbose

# Build wheels
cd plugins_rust && maturin build --release --out dist

# Python integration tests (requires Rust extension built)
cd plugins_rust && make dev
cd plugins_rust && uv run make test-python
cd plugins_rust && uv run make test-differential

# Security audit
cd plugins_rust && cargo install cargo-audit && make audit

# Coverage
cd plugins_rust && cargo install cargo-tarpaulin && uv run make coverage

# Documentation
cd plugins_rust && make doc


## Rust Tools Tests (rust-tools.yml)
# ------------------------------------------------------

# Check formatting
cd tools_rust/wrapper && cargo fmt --check

# Run cargo check
cd tools_rust/wrapper && make check

# Run clippy (pedantic)
cd tools_rust/wrapper && make pedantic

# Run tests
cd tools_rust/wrapper && make test

# Build release
cd tools_rust/wrapper && make build-release

# License check
cd tools_rust/wrapper && cargo install cargo-deny && make licenses

# Coverage
cd tools_rust/wrapper && cargo install cargo-llvm-cov && make coverage


## Quick Test Commands (from Makefile)
# ------------------------------------------------------

# Run all core tests
make test

# Run doctests
make doctest

# Run doctests then unit tests
make doctest test

# Generate HTML coverage report
make htmlcov

# Full coverage (md + HTML + XML + badge + annotated)
make coverage

# Container build + simple E2E flow
make smoketest

# MCP protocol via mcp-cli (needs live gateway)
make test-mcp-cli

# Database performance tests
make test-db-perf

# JMeter load testing
make jmeter-rest-baseline
make jmeter-mcp-baseline
make jmeter-load
make jmeter-stress
make jmeter-report


## Pre-commit Checks
# ------------------------------------------------------

# Format and lint before committing
make autoflake isort black pre-commit

# Full verification suite
make flake8 bandit interrogate pylint verify
